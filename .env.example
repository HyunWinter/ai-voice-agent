# (Optional) Set DEBUG=1 to log all internal realtime events. Leave blank for a quiet output.
DEBUG=

# (Development) If set, `npm run dev` automatically spins up an ngrok tunnel. No separate install required.
# Token: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=
# (Optional) Static domain — 1 free domain available at https://dashboard.ngrok.com/domains (keeps URL fixed across restarts)
NGROK_DOMAIN=


# OpenAI
OPENAI_API_KEY=sk-...
# SIP target project ID
#   Location: https://platform.openai.com/settings/project/general (Prefix: proj_)
OPENAI_PROJECT_ID=proj_...
# Webhook signature verification secret (Prefix: whsec_). Shown only once at creation -> rotate if lost.
#   Location: https://platform.openai.com/settings/project/webhooks -> Create
#     · URL      = https://<public_host>/openai/webhook
#     · Event    = realtime.call.incoming  (Subscribe only to this event, others are irrelevant)
OPENAI_WEBHOOK_SECRET=whsec_...
# Verified: gpt-realtime / gpt-realtime-mini / gpt-realtime-2. mini = recommended for receptionists.
OPENAI_REALTIME_MODEL=gpt-realtime-mini

# Bridge Port
PORT=5050

# (Optional, Recommended) Twilio Auth Token — If set, /voice verifies Twilio signatures to block forged requests. Found in Twilio Console.
TWILIO_AUTH_TOKEN=
